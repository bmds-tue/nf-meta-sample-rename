{
  "name": "nextflow + claude code",
  "image": "nfcore/devcontainer:latest",
  "features": {
    // Node.js LTS is required by the Claude Code CLI
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    }
  },
  "remoteEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
    // Keeps uv and Claude Code binaries on PATH after postCreate
    "PATH": "${containerEnv:PATH}:/root/.local/bin"
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "nextflow.nextflow"
      ]
    }
  }
}